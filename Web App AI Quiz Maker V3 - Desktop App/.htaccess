# Block access to sensitive files
<FilesMatch "\.(env|ini|log|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# Block direct access to config files
<FilesMatch "^(config\.ini|\.env|\.env\.example|client_secret_.*\.json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Protect against XSS via URL injection
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK) [NC]
    RewriteRule .* - [F]
</IfModule>