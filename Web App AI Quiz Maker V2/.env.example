# ============================================
# AI Quiz Maker - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# App Mode: 'web' (browser with Google auth) or 'desktop' (Electron, no auth)
VITE_APP_MODE="web"

# Google Gemini API Key (for bundled Default AI in web mode)
# Get one at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Google OAuth Client ID (only needed in web mode)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# App Settings
VITE_DEFAULT_MODEL="gemini-3-flash-preview"
VITE_MAX_QUESTIONS=30
